#include<stdio.h>
int main(){
    int sum=0;
    double avg; 
    int max;
    int min;
    int n; 
    printf("enter the total numbers: ");
    scanf("%d",&n);
    int num[n];
    printf("enter the numbers:\n");
    for(int i=0;i<n;i++)
    {
        scanf("%d",&num[i]);
    }
    max = num[0];
    min = num[0];
    for(int i=0;i<n;i++)
    {
        sum+=num[i];
        if(num[i] > max) max = num[i];
        if(num[i] < min) min = num[i];
    }
    avg = (double)sum / n;
    printf("Sum = %d\n", sum);
    printf("Average = %.1f\n", avg);
    printf("Maximum = %d\n", max);
    printf("Minimum = %d\n", min);
    
    return 0;
}
